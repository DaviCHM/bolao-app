# Copie para .env e preencha com valores reais (o .env nunca e commitado).

# --- Docker Compose local (servico db) ---
MYSQL_DATABASE=poolbet
MYSQL_USER=poolbet
MYSQL_PASSWORD=troque-esta-senha
MYSQL_ROOT_PASSWORD=troque-esta-senha-root

# --- Deploy com banco MySQL externo (gerenciado) ---
# Bancos gerenciados normalmente exigem TLS; use sslMode=REQUIRED na URL.
# Injete estas variaveis na plataforma de deploy (nao sao usadas pelo compose local):
# SPRING_DATASOURCE_URL=jdbc:mysql://<host>:<porta>/<database>?sslMode=REQUIRED
# SPRING_DATASOURCE_USERNAME=<usuario>
# SPRING_DATASOURCE_PASSWORD=<senha>
